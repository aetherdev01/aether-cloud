# Token bot Telegram (dari @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNOPqrsTUVwxyZ-1234567

# Telegram user ID kamu (admin tunggal). Dapatkan dari @userinfobot
ADMIN_TELEGRAM_ID=123456789

# Path ke serviceAccountKey.json (default: file di folder yang sama dengan bot.js)
# Kalau kamu taruh file-nya di tempat lain, ubah path ini.
SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# WAJIB diisi persis sama dengan project_id di app/google-services.json aplikasi
# Android AetherX-mu. Bot akan menolak jalan (dan kasih pesan error jelas) kalau
# serviceAccountKey.json yang dipakai ternyata untuk project Firebase yang beda —
# ini mencegah lisensi "berhasil dibuat" di bot tapi "tidak ditemukan" di app,
# yang terjadi kalau service account key-nya salah project.
EXPECTED_PROJECT_ID=aether-cloud-df1ca
