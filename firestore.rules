rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /meta/user_counter {
      // Siapa saja boleh baca nilai counter saat ini (opsional, bisa dihapus
      // kalau tidak mau nilai count terbaca publik).
      allow get: if true;

      // Dokumen baru hanya boleh dibuat dengan count = 1 (alokasi user pertama).
      allow create: if request.resource.data.count == 1;

      // Update hanya diterima kalau count naik PERSIS 1 dari nilai sebelumnya
      // (mencegah orang menulis angka sembarangan / lompat jauh).
      allow update: if request.resource.data.count == resource.data.count + 1;

      allow delete: if false;
    }

    match /devices/{deviceId} {
      // Dibuka untuk `get` supaya UserIdRepository bisa memulihkan `userId`
      // yang sudah pernah dialokasikan untuk device ini saat app di-uninstall
      // lalu dipasang ulang (preferensi lokal hilang, tapi dokumen device di
      // Firestore tetap ada, dikunci ke ANDROID_ID sebagai document ID).
      //
      // CATATAN KEAMANAN: karena app ini tidak pakai Firebase Auth, rules
      // tidak punya cara memverifikasi "pemanggil get ini benar pemilik
      // ANDROID_ID tsb" — siapa pun yang tahu/menebak sebuah deviceId bisa
      // ikut membaca dokumennya (isinya cuma timestamp login & nomor urut
      // userId, bukan data sensitif). Kalau ke depan butuh proteksi lebih
      // ketat, tambahkan Firebase Auth anonim dan ganti kondisi ini jadi
      // `request.auth != null && request.auth.uid == deviceId` atau serupa.
      allow get: if true;

      // Dokumen baru: field wajib ada, deviceId di data harus cocok dengan
      // document ID (mencegah orang menulis ke devices/A tapi isi field
      // deviceId-nya "B"), dan firstLoginAt/lastLoginAt harus benar-benar
      // timestamp server saat request diterima (bukan tanggal sembarangan
      // yang dikirim manual dari client).
      allow create: if request.resource.data.deviceId == deviceId
        && request.resource.data.firstLoginAt == request.time
        && request.resource.data.lastLoginAt == request.time
        && request.resource.data.userId is int;

      // Update: deviceId dan firstLoginAt tidak boleh berubah sama sekali
      // (mencegah orang menimpa ulang catatan "login pertama"-nya sendiri).
      // Hanya lastLoginAt (harus == request.time) dan userId yang boleh berubah.
      allow update: if request.resource.data.deviceId == resource.data.deviceId
        && request.resource.data.firstLoginAt == resource.data.firstLoginAt
        && request.resource.data.lastLoginAt == request.time;

      allow delete: if false;
    }

    match /licenses/{key} {
      // CATATAN PENTING: rules ini SAMA SEKALI TIDAK BERLAKU untuk bot Telegram
      // (bot.js). Bot menulis lewat Firestore REST API pakai serviceAccountKey.json
      // (service account / Admin SDK credentials), yang PUNYA HAK AKSES PENUH dan
      // BYPASS security rules ini sepenuhnya. Rules di bawah ini HANYA membatasi
      // apa yang boleh dilakukan APLIKASI ANDROID (client biasa, tanpa credentials
      // admin) langsung ke Firestore.
      //
      // Kalau bot Telegram "berhasil generate" tapi lisensinya tidak muncul di
      // Firebase Console / tidak kebaca app, PENYEBABNYA BUKAN rules ini — cek
      // apakah serviceAccountKey.json yang dipakai bot benar-benar untuk project
      // Firebase yang sama dengan app/google-services.json (lihat EXPECTED_PROJECT_ID
      // di bot.js/.env).

      // Dokumen lisensi HANYA dibuat lewat bot Telegram (service account, bypass
      // rules ini). Client Android tidak pernah boleh membuat kode lisensinya sendiri.
      allow create: if false;

      // Boleh dibaca untuk mengecek status (dipakai LicenseGateScreen saat
      // revalidasi dari cache lokal).
      allow get: if true;

      // Update HANYA diterima sebagai aktivasi kode yang belum terpakai:
      // - deviceId sebelumnya harus null (belum pernah diaktivasi siapa pun)
      // - deviceId baru harus diisi (string non-kosong) — devicenya sendiri
      //   tidak bisa diverifikasi dari sisi rules (client bisa kirim device ID
      //   apa saja), makanya field lain yang sensitif (expiresAt, status lama)
      //   dikunci ketat supaya kerusakan akibat penyalahgunaan ini terbatas.
      // - status berubah dari "unused" ke "active" saja (tidak bisa langsung
      //   ke status lain, dan tidak bisa mengubah lisensi yang sudah revoked).
      // - activatedAt harus timestamp server asli (request.time).
      // - expiresAt TIDAK BOLEH berubah sama sekali lewat client (hanya bot
      //   Telegram, lewat service account, yang bisa memperpanjang/mempersingkat
      //   masa berlaku).
      // - note (field opsional dari bot) tidak boleh diubah lewat client.
      allow update: if resource.data.deviceId == null
        && resource.data.status == "unused"
        && request.resource.data.deviceId is string
        && request.resource.data.deviceId.size() > 0
        && request.resource.data.status == "active"
        && request.resource.data.activatedAt == request.time
        && request.resource.data.expiresAt == resource.data.expiresAt
        && request.resource.data.createdAt == resource.data.createdAt;

      // Hanya bot Telegram (service account) yang boleh menghapus lisensi.
      allow delete: if false;
    }
  }
}
