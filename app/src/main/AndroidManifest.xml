<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.aether.x">

    <!-- Wajib di Android 11+ (API 30) agar getPackageInfo/getLaunchIntentForPackage
         untuk Free Fire & Free Fire MAX tidak diblokir package visibility filtering. -->
    <queries>
        <package android:name="com.dts.freefireth" />
        <package android:name="com.dts.freefire.max" />
    </queries>

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".AetherXApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.AetherX"
        android:localeConfig="@xml/locales_config"
        android:usesCleartextTraffic="false">

        <!-- Memastikan pilihan bahasa (AppCompatDelegate.setApplicationLocales) tetap
             tersimpan dan otomatis dipulihkan lewat mekanisme resmi per-app language,
             termasuk di Android versi lama yang tidak native mendukungnya (di bawah 13). -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AetherX.Splash"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|keyboardHidden|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Shizuku binder provider — wajib untuk mode non-root.
             Diproteksi dengan INTERACT_ACROSS_USERS_FULL agar tidak bisa
             diakses sembarang aplikasi lain. -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!-- Overlay crosshair: foreground service, "specialUse" karena menampilkan
             elemen bantu di atas aplikasi lain (bukan media/lokasi/dll bawaan Android). -->
        <service
            android:name=".core.overlay.CrosshairOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="crosshair_overlay" />
        </service>

        <!-- Overlay Monitor FPS: sama seperti crosshair, foreground service
             "specialUse" untuk menampilkan panel statistik (FPS/CPU/GPU/suhu)
             di atas aplikasi lain. -->
        <service
            android:name=".core.overlay.FpsMonitorOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="fps_monitor_overlay" />
        </service>

    </application>
</manifest>
