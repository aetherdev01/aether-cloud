    <!-- Onboarding — Setup Permission -->
    <string name="setup_title">Set Up Access</string>
    <string name="setup_subtitle">AetherX needs one of the following access methods to adjust your device\'s touch sensitivity, DPI, and refresh rate.</string>
    <string name="setup_required_banner">Enable one of these before continuing</string>
    <string name="setup_method_shizuku">Shizuku (No Root)</string>
    <string name="setup_method_shizuku_desc">Great for non-rooted phones. Requires the Shizuku app active via Wireless Debugging.</string>
    <string name="setup_method_root">Root (Magisk / KernelSU / APatch)</string>
    <string name="setup_method_root_desc">For rooted phones. AetherX will request superuser (su) access.</string>
