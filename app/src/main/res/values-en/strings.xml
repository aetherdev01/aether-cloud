    <!-- Settings — FPS Monitor -->
    <string name="settings_section_fps_monitor">FPS Monitor ( Beta )</string>
    <string name="fps_monitor_enable">Show FPS Monitor</string>
    <string name="fps_monitor_enable_desc">A small overlay showing FPS, CPU, GPU, and device temperature in real time.</string>
    <string name="fps_monitor_permission_needed">Requires "Display over other apps" permission. Tap the switch above to open permission settings.</string>
    <string name="fps_monitor_style_label">Display Style</string>
    <string name="fps_monitor_style_rog">ROG Style</string>
    <string name="fps_monitor_style_rog_desc">Full card (FPS, CPU, GPU, temperature) — can be freely dragged anywhere.</string>
    <string name="fps_monitor_style_classic">Classic</string>
    <string name="fps_monitor_style_classic_desc">Compact single-line pill — fixed at the bottom-left corner of the screen.</string>
    <string name="fps_monitor_position_locked_hint">Classic style is always locked to the bottom-left corner and cannot be dragged.</string>
    <string name="fps_monitor_position_draggable_hint">Press and drag the panel on screen to move it. Position is saved automatically.</string>
    <string name="fps_monitor_gpu_disclaimer">GPU readout depends on your device chipset — shows "-" if unsupported.</string>
    <string name="fps_monitor_accuracy_disclaimer">FPS is read directly from the running game (not the screen\'s Hz), requires active Shizuku or Root access for accurate readings.</string>
