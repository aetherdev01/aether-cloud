<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31+): use M3 Dynamic Color (wallpaper-based) for LIGHT mode. -->
    <style name="Theme.AetherCloud" parent="Theme.Material3.DynamicColors.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.AetherCloud.Login" parent="Theme.AetherCloud" />
</resources>
