<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Default theme: M3 standard LIGHT. Dark mode is provided via values-night/themes.xml. -->
    <style name="Theme.AetherCloud" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/md_primary_light</item>
        <item name="colorOnPrimary">@color/md_on_primary_light</item>
        <item name="colorPrimaryContainer">@color/md_primary_container_light</item>
        <item name="colorOnPrimaryContainer">@color/md_on_primary_container_light</item>
        <item name="colorSecondary">@color/md_secondary_light</item>
        <item name="colorOnSecondary">@color/md_on_secondary_light</item>
        <item name="colorSecondaryContainer">@color/md_secondary_container_light</item>
        <item name="colorOnSecondaryContainer">@color/md_on_secondary_container_light</item>
        <item name="colorTertiary">@color/md_tertiary_light</item>
        <item name="colorOnTertiary">@color/md_on_tertiary_light</item>
        <item name="colorError">@color/md_error_light</item>
        <item name="colorOnError">@color/md_on_error_light</item>
        <item name="colorErrorContainer">@color/md_error_container_light</item>
        <item name="colorOnErrorContainer">@color/md_on_error_container_light</item>
        <item name="colorSurface">@color/md_surface_light</item>
        <item name="colorOnSurface">@color/md_on_surface_light</item>
        <item name="colorSurfaceVariant">@color/md_surface_variant_light</item>
        <item name="colorOnSurfaceVariant">@color/md_on_surface_variant_light</item>
        <item name="colorOutline">@color/md_outline_light</item>
        <item name="colorOutlineVariant">@color/md_outline_variant_light</item>
        <item name="colorSurfaceContainer">@color/md_surface_container_light</item>
        <item name="colorSurfaceContainerHigh">@color/md_surface_container_high_light</item>
        <item name="colorSurfaceDim">@color/md_surface_dim_light</item>
        <item name="colorInverseSurface">@color/md_inverse_surface_light</item>
        <item name="colorOnInverseSurface">@color/md_inverse_on_surface_light</item>
        <item name="android:colorBackground">@color/md_surface_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/md_surface_light</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Splash / Login: no action bar -->
    <style name="Theme.AetherCloud.Login" parent="Theme.AetherCloud" />
</resources>
