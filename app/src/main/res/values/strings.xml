    <!-- Onboarding — Guide -->
    <string name="guide_skip">Lewati</string>
    <string name="guide_next">Lanjut</string>
    <string name="guide_finish">Mulai Pakai</string>
    <string name="guide_title_1">Selamat Datang di AetherX</string>
    <string name="guide_body_1">Optimalkan respons sentuhan layar HP kamu sebelum mabar Free Fire. Atur DPI, resolusi, kecepatan pointer, dan refresh rate dalam satu tempat.</string>
    <string name="guide_title_2">Kenapa Layar Terasa \'Licin\'?</string>
    <string name="guide_body_2">Menurunkan DPI dan resolusi membuat pemetaan sentuhan ke piksel jadi lebih presisi, sementara refresh rate tinggi membuat gerakan terasa lebih halus dan responsif.</string>
    <string name="guide_title_3">Aman &amp; Bisa Dikembalikan</string>
    <string name="guide_body_3">Semua perubahan memakai perintah sistem Android resmi (wm, settings) dan bisa dikembalikan ke pengaturan pabrik kapan saja lewat tombol Reset.</string>
    <string name="guide_title_4">Siap Tweak</string>
    <string name="guide_body_4">Buka tab Tweak, geser slider sesuai selera, lalu tekan Terapkan. Hasilnya langsung terasa di sistem, termasuk saat main Free Fire.</string>

