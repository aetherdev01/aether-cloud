    <!-- Tweak khusus root -->
    <string name="tweak_section_root">Kernel Tuning (Root)</string>
    <string name="tweak_cpu_performance">CPU Governor: Performance</string>
    <string name="tweak_cpu_performance_desc">Kunci semua core CPU ke clock speed maksimum (governor performance) selama bermain, mengurangi micro-stutter akibat naik-turun frekuensi. Butuh akses root.</string>
    <string name="tweak_ram_priority">Swappiness Override</string>
    <string name="tweak_ram_priority_desc">Turunkan nilai swappiness kernel supaya sistem lebih jarang menukar data game ke swap/zram, menjaga game tetap di RAM. Butuh akses root.</string>
    <string name="tweak_thermal_throttle">Thermal Throttle Override</string>
    <string name="tweak_thermal_throttle_desc">Naikkan batas suhu trip point kernel sebelum sistem menurunkan clock CPU/GPU (throttling). Berguna untuk sesi main lama, tapi tingkatkan suhu perangkat — pakai dengan hati-hati. Butuh akses root.</string>
    <string name="tweak_gpu_performance">GPU Governor: Performance</string>
    <string name="tweak_gpu_performance_desc">Kunci frekuensi GPU ke clock maksimum yang didukung selama bermain, mengurangi drop FPS akibat governor GPU turun-naik. Butuh akses root.</string>
